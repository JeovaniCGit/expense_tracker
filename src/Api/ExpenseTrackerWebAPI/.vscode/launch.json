{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Api/ExpenseTrackerWebAPI/bin/Debug/net7.0/ExpenseTracker.API.dll",
      "args": ["--urls", "http://localhost:0"],
      "cwd": "${workspaceFolder}/Api/ExpenseTrackerWebAPI",
      "stopAtEntry": false,
      "serverReadyAction": {
        "pattern": "Now listening on: (https?://\\S+)",
        "action": "openExternally"
      },
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    }
  ]
}